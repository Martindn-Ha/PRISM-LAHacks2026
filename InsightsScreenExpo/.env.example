# Optional spotlight image URL (HTTPS)
EXPO_PUBLIC_COMMUNITY_SPOTLIGHT_IMAGE_URL=https://example.com/sample.jpg

# Firebase Web App Config
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id

# Backend endpoints
EXPO_PUBLIC_ARISTA_CONTEXT_URL=https://us-west1-your-project-id.cloudfunctions.net/nearbyEventContext
EXPO_PUBLIC_ARISTA_COMMUNITY_EVENTS_URL=https://us-west1-your-project-id.cloudfunctions.net/communityEvents
